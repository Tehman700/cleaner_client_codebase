# ── App PINs ──────────────────────────────────────────────
ADMIN_PIN=changeme
CLEANER_PIN=changeme

# ── Database ──────────────────────────────────────────────
DATABASE_URL=sqlite:///./cleantrack.db

# ── Analytics dashboard login ─────────────────────────────
TRACKING_USER=admin
TRACKING_PASSWORD=changeme
TRACKING_SECRET=replace_with_a_long_random_string

# ── Scheduled auto-reset ──────────────────────────────────
# Shared secret the GitHub Actions cron sends to trigger the reset.
# Must match the CRON_SECRET GitHub repo secret.
CRON_SECRET=replace_with_a_long_random_string

# Timezone offset for bucketing analytics (Pakistan = 5)
TZ_OFFSET_HOURS=5

# Auto-reset: wipe interval and scope ("analytics" = events only, "all" = whole DB)
RESET_INTERVAL_DAYS=14
RESET_SCOPE=analytics
