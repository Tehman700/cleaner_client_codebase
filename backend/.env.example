# ── App PINs ──────────────────────────────────────────────
ADMIN_PIN=changeme
CLEANER_PIN=changeme

# ── Database ──────────────────────────────────────────────
DATABASE_URL=sqlite:///./cleantrack.db

# ── Analytics dashboard login ─────────────────────────────
TRACKING_USER=admin
TRACKING_PASSWORD=changeme
TRACKING_SECRET=replace_with_a_long_random_string

# ── Scheduled email + auto-reset ──────────────────────────
# Gmail SMTP — SMTP_PASSWORD must be a Gmail APP PASSWORD (16 chars),
# generated at https://myaccount.google.com/apppasswords (2FA required).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=wguru2107@gmail.com
SMTP_PASSWORD=your_gmail_app_password
REPORT_TO=wguru2107@gmail.com

# Shared secret the GitHub Actions cron sends to trigger report/reset.
# Must match the CRON_SECRET GitHub repo secret.
CRON_SECRET=replace_with_a_long_random_string

# Timezone offset for bucketing analytics (Pakistan = 5)
TZ_OFFSET_HOURS=5

# Auto-reset: wipe interval and scope ("analytics" = events only, "all" = whole DB)
RESET_INTERVAL_DAYS=14
RESET_SCOPE=analytics
